# ═══════════════════════════════════════════════════════════════
# MCP Security Stack — Environment Configuration
# Copy this file to .env and fill in your values before starting.
#
# Generate a Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Generate random API keys:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ═══════════════════════════════════════════════════════════════


# ── OAuth Server (:8080) ─────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_CODE_EXPIRE_MINUTES=10
REQUIRE_PKCE=true


# ── Audit Server (:8081) ─────────────────────────────────────────

# MCP servers use this key to POST events
AUDIT_INGEST_API_KEY=change-me-audit-ingest-key

# Compliance tooling uses this key to read/query/export events
AUDIT_READ_API_KEY=change-me-audit-read-key

# Optional: forward every event to a SIEM in real time
SIEM_WEBHOOK_URL=
SIEM_WEBHOOK_API_KEY=

RETENTION_DAYS=365


# ── Gateway (:8082) ──────────────────────────────────────────────

# Admin key for registering servers and managing policies
GATEWAY_ADMIN_KEY=change-me-gateway-admin-key

# Gateway's own OAuth credentials (register it as a confidential client
# via POST /register on the OAuth server, then paste the values here)
GATEWAY_OAUTH_CLIENT_ID=
GATEWAY_OAUTH_CLIENT_SECRET=

DEFAULT_RATE_LIMIT_RPM=60
DEFAULT_RATE_LIMIT_RPD=10000
BACKEND_TIMEOUT_SECONDS=30


# ── Secrets Server (:8083) ───────────────────────────────────────

# Master encryption key for the LOCAL backend (AES-128-CBC via Fernet)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# Admin key for registering secrets and managing access policies
SECRETS_ADMIN_KEY=change-me-secrets-admin-key

# MCP servers use this key to request leases
SECRETS_INGEST_KEY=change-me-secrets-ingest-key

DEFAULT_LEASE_TTL_SECONDS=300
MAX_LEASE_TTL_SECONDS=3600

# ── HashiCorp Vault (optional — leave blank to use local backend)
VAULT_ADDR=
VAULT_TOKEN=
VAULT_NAMESPACE=
VAULT_MOUNT=secret

# ── AWS Secrets Manager (optional)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── GCP Secret Manager (optional)
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=


# ── PII Filter (:8084) ───────────────────────────────────────────

# Admin key for managing filter rules and viewing detection summaries
PII_ADMIN_KEY=change-me-pii-admin-key

# MCP servers / the Gateway use this key to submit payloads for filtering
PII_FILTER_KEY=change-me-pii-filter-key

# Default redaction strategy: REDACT | MASK | HASH | FLAG
DEFAULT_STRATEGY=REDACT
