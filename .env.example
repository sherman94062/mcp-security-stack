# MCP OAuth Server Configuration

# Server
HOST=0.0.0.0
PORT=8080
BASE_URL=http://localhost:8080

# Security
SECRET_KEY=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_CODE_EXPIRE_MINUTES=10

# Database (SQLite for local dev, swap for Postgres in prod)
DATABASE_URL=sqlite+aiosqlite:///./mcp_oauth.db

# PKCE
REQUIRE_PKCE=true

# Allowed redirect URI patterns (comma-separated, supports wildcards)
ALLOWED_REDIRECT_URIS=http://localhost:*,https://*.yourdomain.com
